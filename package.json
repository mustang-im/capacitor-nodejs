{
  "name": "capacitor-nodejs",
  "version": "1.0.0-beta.9",
  "description": "A full-fledged Node.js runtime for Capacitor apps",
  "type": "module",
  "main": "dist/plugin.cjs.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "unpkg": "dist/plugin.js",
  "files": [
    "android/src/main/",
    "android/build.gradle",
    "android/CMakeLists.txt",
    "assets/",
    "dist/",
    "ios/Plugin/",
    "electron/",
    "scripts/dist/",
    "CapacitorNodejs.podspec"
  ],
  "author": "Rene Hampölz",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hampoelz/Capacitor-NodeJS.git"
  },
  "bugs": {
    "url": "https://github.com/hampoelz/Capacitor-NodeJS/issues"
  },
  "keywords": [
    "capacitor",
    "plugin",
    "native"
  ],
  "scripts": {
    "verify": "npm run verify:ios && npm run verify:android && npm run verify:web",
    "verify:ios": "cd ios && pod install && xcodebuild -workspace Plugin.xcworkspace -scheme Plugin && cd ..",
    "verify:android": "cd android && ./gradlew clean build test && cd ..",
    "verify:web": "npm run build",
    "lint": "npm run eslint && npm run prettier -- --check && npm run swiftlint -- lint",
    "fmt": "npm run eslint -- --fix && npm run prettier -- --write && npm run swiftlint -- autocorrect --format",
    "eslint": "eslint . --ext ts",
    "prettier": "prettier \"**/*.{css,html,ts,js,java}\" --plugin=prettier-plugin-java",
    "swiftlint": "node-swiftlint",
    "docgen": "docgen --api NodeJSInterface --output-readme README.md --output-json dist/docs.json",
    "build-bridge": "tsc --project bridge/tsconfig.json && rollup -c bridge/rollup.config.mjs && rimraf ./bridge/build",
    "build-electron": "tsc --project electron/tsconfig.json && rollup -c electron/rollup.config.mjs && rimraf ./electron/build",
    "build-scripts": "cd scripts && vite build --config vite.config.ts && chmod +x dist/after-copy.js dist/rebuild-native-module.js",
    "build": "npm run clean && npm run docgen && tsc && rollup -c rollup.config.mjs && npm run build-electron && npm run build-bridge && npm run build-scripts",
    "clean": "rimraf ./dist && rimraf ./scripts/dist",
    "watch": "tsc --watch",
    "pack:bridge": "cd assets/types/bridge && npm pack --pack-destination ../ && mv ../types-bridge-*.tgz ../bridge.tgz",
    "pack": "npm run pack:bridge && npm pack",
    "fetch-libnode": "node scripts/dist/after-copy.js",
    "capacitor:copy:after": "node scripts/dist/after-copy.js",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "nodejs-mobile-gyp": "^0.4.0"
  },
  "devDependencies": {
    "@capacitor/android": "^7.0.0",
    "@capacitor/cli": "^7.0.0",
    "@capacitor/core": "^7.0.0",
    "@capacitor/docgen": "^0.3.0",
    "@capacitor/ios": "^7.0.0",
    "@ionic/eslint-config": "^0.4.0",
    "@ionic/prettier-config": "^4.0.0",
    "@ionic/swiftlint-config": "^2.0.0",
    "@rollup/plugin-commonjs": "^28.0.3",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "adm-zip": "^0.5.16",
    "electron": "^26.2.2",
    "glob": "^11.0.3",
    "eslint": "^8.57.0",
    "prettier": "^3.4.2",
    "prettier-plugin-java": "^2.6.6",
    "rimraf": "^6.0.1",
    "rollup": "^4.30.1",
    "rollup-plugin-copy": "^3.5.0",
    "rollup-plugin-dts": "^6.2.1",
    "swiftlint": "^2.0.0",
    "typescript": "^4.5.0",
    "vite": "^7.1.2"
  },
  "peerDependencies": {
    "@capacitor/core": ">=7.0.0"
  },
  "prettier": "@ionic/prettier-config",
  "swiftlint": "@ionic/swiftlint-config",
  "eslintConfig": {
    "extends": "@ionic/eslint-config/recommended"
  },
  "capacitor": {
    "ios": {
      "src": "ios"
    },
    "android": {
      "src": "android"
    },
    "electron": {
      "src": "electron"
    }
  }
}
